# Variables de ejemplo para ejecución con Docker Compose.
# docker-compose.yml ya define los valores necesarios; este archivo es referencia.

# Backend
DB_HOST=mysql
DB_PORT=3306
DB_NAME=estadiapro
DB_USER=root
DB_PASSWORD=root
JWT_SECRET=estadiapro-secret-docker

# Frontend
BACKEND_INTERNAL_URL=http://backend:4000
