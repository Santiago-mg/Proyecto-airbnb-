extends ../layout/base
include ../partials/alert

block contenido
  section.container-app.flex.items-center.justify-center.py-12(class="min-h-[70vh]")
    .card.w-full.max-w-md.p-8(class="sm:p-10")
      span.flex.h-14.w-14.items-center.justify-center.rounded-2xl.bg-brand-100.text-brand-700
        i(data-lucide="key-round" style="width:26px;height:26px")
      h1.mt-5.font-display.text-2xl.font-bold.text-ink Recupera tu acceso
      p.mt-2.text-sm.text-ink-muted Ingresa tu correo y te enviaremos instrucciones para restablecer tu contraseña.

      if alert
        .mt-6
          +alert(alert)

      form.mt-6.space-y-4(method="POST" action="/olvide-password")
        div
          label.label(for="email") Correo electrónico
          input#email.field(type="email" name="email" placeholder="tucorreo@ejemplo.com" required)
        button.btn-primary.w-full(type="submit") Enviar instrucciones
      a.mt-4.flex.items-center.justify-center.gap-1.text-sm.font-semibold.text-brand-700(href="/login")
        i(data-lucide="arrow-left" style="width:16px;height:16px")
        | Volver a iniciar sesión
