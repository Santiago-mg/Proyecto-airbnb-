extends ../layout/index

block contenido
  .block.mx-auto.max-w-md.py-10
    h1.text-4xl.my-10.font-extrabold.text-center Bienes
      span.font-normal Raices
    h2.text-center.text-2xl.font-extrabold= pagina

  .mt-8.mx-auto.max-w-md
    include ../partials/alert
    .bg-white.py-8.px-4.shadow.rounded-2xl
      if errores.length
        div(class="max-w-md mx-auto my-10")
          each error in errores
            p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

      form.space-y-5(method="POST" action="/api/auth/login" novalidate)
        div
          label.block.text-sm.uppercase.text-gray-500.mb-3.font-bold(for="email") Email de registro
          input#email.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-400(
            placeholder="Tu email"
            type="email"
            name="email"
            value= usuario ? usuario.email : ''
          )

        div
          label.block.text-sm.uppercase.text-gray-500.mb-3.font-bold(for="password") Password
          input#password.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-400(
            placeholder="Tu password"
            type="password"
            name="password"
          )

        div.flex.items-center.justify-between
          a.text-gray-500.text-xs(href='/registro') No tienes cuenta? Crea una
          a.text-gray-500.text-xs(href='/olvide-password') Olvide mi password

        input(
          class="w-full rounded-md bg-indigo-600 py-3 font-bold text-white cursor-pointer hover:bg-indigo-700"
          type="submit"
          value="Iniciar sesion"
        )
