extends _layout
include ../partials/mixins

block panel
  h1.font-display.text-3xl.font-bold.text-ink Mis favoritos
  p.mt-1.text-ink-muted Las estadías que guardaste para después.

  if propiedades.length
    .mt-6.grid.gap-6(class="sm:grid-cols-2 xl:grid-cols-3")
      each p in propiedades
        +propertyCard(p, favoritos)
  else
    .card.mt-6.flex.flex-col.items-center.gap-3.p-12.text-center
      i(data-lucide="heart-off" class="text-brand-400" style="width:44px;height:44px")
      h3.font-display.text-xl.font-bold.text-ink Aún no tienes favoritos
      p.text-ink-muted Toca el corazón en cualquier propiedad para guardarla aquí.
      a.btn-primary(href="/") Descubrir estadías
