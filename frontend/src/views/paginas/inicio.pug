extends ../layout/base
include ../partials/mixins
include ../partials/alert

block contenido
  //- HERO
  section.relative.overflow-hidden
    .aurora-bg.absolute.inset-0
    .absolute.inset-0(class="bg-black/10")
    .container-app.relative.py-20(class="lg:py-28")
      .max-w-3xl.animate-fade-up
        span.chip.mb-5
          i(data-lucide="sparkles" class="text-coral-500" style="width:14px;height:14px")
          | Más de #{propiedades.length} estadías verificadas
        h1.font-display.text-4xl.font-bold.leading-tight.text-white(class="sm:text-5xl lg:text-6xl")
          | Tu próxima
          span.text-brand-200  estadía
          br
          | empieza aquí.
        p.mt-5.max-w-xl.text-lg.text-brand-50(class="text-white/90")
          | Descubre apartamentos, cabañas y villas únicas. Reserva en segundos con anfitriones de confianza.

      //- Buscador
      form.relative.mt-10.animate-fade-up(action="/" method="GET")
        .grid.gap-3.rounded-4xl.bg-white.p-3.shadow-float(class="md:grid-cols-[1.4fr_1fr_0.8fr_auto]")
          label.flex.items-center.gap-3.rounded-3xl.px-4.py-3(class="hover:bg-brand-50")
            i(data-lucide="map-pin" class="text-brand-600" style="width:20px;height:20px")
            span.flex-1
              span.block.text-xs.font-bold.uppercase.tracking-wide.text-ink-muted Destino
              input.w-full.border-0.bg-transparent.p-0.text-sm.font-medium.text-ink.outline-none(class="focus:ring-0" type="text" name="q" placeholder="¿A dónde vas?" value=(filtros.q || ''))
          label.flex.items-center.gap-3.rounded-3xl.px-4.py-3(class="hover:bg-brand-50")
            i(data-lucide="layers" class="text-brand-600" style="width:20px;height:20px")
            span.flex-1
              span.block.text-xs.font-bold.uppercase.tracking-wide.text-ink-muted Tipo
              select.w-full.border-0.bg-transparent.p-0.text-sm.font-medium.text-ink.outline-none(class="focus:ring-0" name="categoriaId")
                option(value="") Cualquiera
                each c in categorias
                  option(value=c.id selected=(String(filtros.categoriaId) === String(c.id)))= c.nombre
          label.flex.items-center.gap-3.rounded-3xl.px-4.py-3(class="hover:bg-brand-50")
            i(data-lucide="users" class="text-brand-600" style="width:20px;height:20px")
            span.flex-1
              span.block.text-xs.font-bold.uppercase.tracking-wide.text-ink-muted Huéspedes
              input.w-full.border-0.bg-transparent.p-0.text-sm.font-medium.text-ink.outline-none(class="focus:ring-0" type="number" min="1" name="huespedes" placeholder="2" value=(filtros.huespedes || ''))
          button.btn-primary.h-full.px-6(type="submit")
            i(data-lucide="search" style="width:18px;height:18px")
            span.hidden(class="sm:inline") Buscar

  //- CATEGORIAS
  section.container-app.mt-10
    .flex.gap-3.overflow-x-auto.pb-2.no-scrollbar
      a.chip.shrink-0(class=(!filtros.categoriaId ? "ring-2 ring-brand-500" : "") href="/")
        i(data-lucide="globe" style="width:15px;height:15px")
        | Todas
      each c in categorias
        a.chip.shrink-0(class=(String(filtros.categoriaId) === String(c.id) ? "ring-2 ring-brand-500" : "") href=`/?categoriaId=${c.id}`)
          i(data-lucide=(c.icono || 'home') style="width:15px;height:15px")
          = c.nombre

  if alert
    .container-app.mt-6
      +alert(alert)

  //- DESTACADAS
  if destacadas && destacadas.length
    section.container-app.mt-14
      .mb-6.flex.items-end.justify-between
        div
          p.text-sm.font-bold.uppercase.tracking-wide.text-coral-500 Selección premium
          h2.font-display.text-3xl.font-bold.text-ink Estadías destacadas
        a.hidden.text-sm.font-semibold.text-brand-700.link-underline(class="sm:block" href="/?destacada=1") Ver todas
      .grid.gap-6(class="md:grid-cols-3")
        each p in destacadas
          +propertyCard(p, favoritos)

  //- GRID PRINCIPAL
  section.container-app.mt-16
    .mb-6.flex.flex-wrap.items-end.justify-between.gap-4
      div
        h2.font-display.text-3xl.font-bold.text-ink Explora todas las estadías
        p.mt-1.text-sm.text-ink-muted #{propiedades.length} resultados disponibles
      form.flex.items-center.gap-2(action="/" method="GET")
        if filtros.q
          input(type="hidden" name="q" value=filtros.q)
        if filtros.categoriaId
          input(type="hidden" name="categoriaId" value=filtros.categoriaId)
        label.text-sm.font-semibold.text-ink-soft(for="orden") Ordenar:
        select#orden.field.w-auto.py-2(name="orden" onchange="this.form.submit()")
          option(value="" selected=(!filtros.orden)) Recomendados
          option(value="precio_asc" selected=(filtros.orden==='precio_asc')) Precio: menor a mayor
          option(value="precio_desc" selected=(filtros.orden==='precio_desc')) Precio: mayor a menor
          option(value="populares" selected=(filtros.orden==='populares')) Más populares

    if propiedades.length
      .grid.gap-6(class="sm:grid-cols-2 lg:grid-cols-3")
        each p in propiedades
          +propertyCard(p, favoritos)
    else
      .card.flex.flex-col.items-center.justify-center.gap-3.p-16.text-center
        i(data-lucide="search-x" class="text-brand-400" style="width:48px;height:48px")
        h3.font-display.text-xl.font-bold.text-ink No encontramos estadías
        p.text-sm.text-ink-muted Prueba con otros filtros o explora todas las propiedades.
        a.btn-ghost(href="/") Limpiar filtros

  //- CTA ANFITRION
  section.container-app.mt-20
    .relative.overflow-hidden.rounded-4xl.bg-brand-900.p-10(class="lg:p-16")
      .aurora-bg.absolute.inset-0.opacity-40
      .relative.grid.items-center.gap-8(class="lg:grid-cols-2")
        div
          h2.font-display.text-3xl.font-bold.text-white(class="lg:text-4xl") Convierte tu espacio en ingresos
          p.mt-4.max-w-md.text-brand-100 Publica tu propiedad en minutos, gestiona reservas y recibe huéspedes de todo el mundo. Sin complicaciones.
          a.btn-primary.mt-6(href="/registro?rol=anfitrion")
            i(data-lucide="plus-circle" style="width:18px;height:18px")
            | Conviértete en anfitrión
        .grid.grid-cols-3.gap-4
          each item in [{n:'verified',t:'Verificado'},{n:'shield-check',t:'Pagos seguros'},{n:'headphones',t:'Soporte 24/7'}]
            .rounded-3xl.bg-white_10.p-5.text-center.backdrop-blur(class="bg-white/10")
              i(data-lucide=item.n class="mx-auto text-coral-400" style="width:28px;height:28px")
              p.mt-2.text-sm.font-semibold.text-white= item.t
