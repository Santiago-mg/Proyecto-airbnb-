extends ../layout/base

block contenido
  section.container-app.flex.flex-col.items-center.justify-center.py-20.text-center(class="min-h-[60vh]")
    span.flex.h-20.w-20.items-center.justify-center.rounded-3xl.bg-brand-100.text-brand-700
      i(data-lucide="compass" style="width:40px;height:40px")
    h1.mt-6.font-display.text-3xl.font-bold.text-ink= pagina
    p.mt-3.max-w-md.text-ink-muted= mensaje
    a.btn-dark.mt-8(href=(hrefBoton || '/'))
      i(data-lucide="arrow-left" style="width:18px;height:18px")
      = textoBoton || 'Volver al inicio'
