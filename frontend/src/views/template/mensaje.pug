extends ../layout/index

block contenido
  .mx-auto.max-w-2xl.py-16
    .rounded-3xl.bg-white.p-10.shadow-2xl
      p(class="mb-4 text-sm font-semibold uppercase tracking-[0.3em] text-indigo-600") Estado de la operacion
      h1.mb-4.text-3xl.font-extrabold.text-slate-900= pagina
      include ../partials/alert
      if mensaje
        p.text-lg.leading-relaxed.text-slate-600= mensaje
      if hrefBoton && textoBoton
        a(
          class="inline-flex mt-8 rounded-2xl bg-indigo-600 px-6 py-3 font-bold text-white transition duration-300 hover:-translate-y-1 hover:bg-indigo-700 hover:shadow-xl"
          href=hrefBoton
        )= textoBoton
