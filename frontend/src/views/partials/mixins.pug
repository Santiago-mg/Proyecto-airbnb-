//- Estrellas de calificación
mixin stars(rating, size)
  -
    var r = Math.round(Number(rating) || 0);
    var px = size || 16;
  span.inline-flex.items-center.gap-1(aria-label=`Calificación ${r} de 5`)
    each n in [1,2,3,4,5]
      i(data-lucide="star" class=(n <= r ? "fill-amber-400 text-amber-400" : "text-slate-300") style=`width:${px}px;height:${px}px`)

//- Avatar con iniciales o imagen
mixin avatar(usuario, size)
  -
    var s = size || 40;
    var ini = (usuario && usuario.nombre ? usuario.nombre.split(' ').filter(Boolean).slice(0,2).map(p => p[0].toUpperCase()).join('') : '?');
  if usuario && usuario.avatar
    img.rounded-full.object-cover.ring-2.ring-white(src=usuario.avatar alt=usuario.nombre style=`width:${s}px;height:${s}px`)
  else
    span.inline-flex.items-center.justify-center.rounded-full.bg-brand-700.font-bold.text-white(style=`width:${s}px;height:${s}px;font-size:${s/2.6}px`)= ini

//- Tarjeta de propiedad
mixin propertyCard(p, favoritos)
  -
    var fav = favoritos && favoritos.indexOf(p.id) !== -1;
    var portada = (p.imagenes && p.imagenes.length) ? p.imagenes[0] : 'https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?auto=format&fit=crop&w=1280&q=80';
  article.group.animate-fade-up
    a.block.overflow-hidden.rounded-4xl.bg-white.shadow-card.transition.duration-300.hover_-translate-y-1.hover_shadow-float(href=`/propiedades/${p.id}` class="hover:-translate-y-1")
      .relative.overflow-hidden(class="aspect-[4/3]")
        img.h-full.w-full.object-cover.transition.duration-500(class="group-hover:scale-105" src=portada alt=p.titulo loading="lazy")
        if p.destacada
          span.absolute.left-4.top-4.badge.bg-white.text-brand-800.shadow-soft
            i(data-lucide="sparkles" style="width:13px;height:13px")
            | Destacada
        button.absolute.right-4.top-4.flex.h-10.w-10.items-center.justify-center.rounded-full.bg-white_90.text-coral-500.shadow-soft.transition.hover_scale-110.js-fav(class="bg-white/90 hover:scale-110" data-id=p.id aria-label="Guardar en favoritos")
          i(data-lucide="heart" class=(fav ? "fill-coral-500 text-coral-500" : "") style="width:18px;height:18px")
      .p-5
        .flex.items-start.justify-between.gap-3
          div
            p.text-xs.font-semibold.uppercase.tracking-wide.text-brand-600= (p.categoria && p.categoria.nombre) || 'Estadía'
            h3.mt-1.font-display.text-lg.font-semibold.leading-tight.text-ink= p.titulo
          if p.rating
            span.flex.shrink-0.items-center.gap-1.text-sm.font-semibold.text-ink
              i(data-lucide="star" class="fill-amber-400 text-amber-400" style="width:15px;height:15px")
              = Number(p.rating).toFixed(1)
        p.mt-1.flex.items-center.gap-1.text-sm.text-ink-muted
          i(data-lucide="map-pin" style="width:14px;height:14px")
          = `${p.ciudad}, ${p.pais}`
        p.mt-3.text-sm.text-ink-muted
          | #{p.huespedes} huéspedes · #{p.habitaciones} hab · #{p.banos} baños
        p.mt-3
          span.font-display.text-xl.font-bold.text-ink= helpers.formatearPrecio(p.precioNoche)
          span.text-sm.text-ink-muted  / noche
