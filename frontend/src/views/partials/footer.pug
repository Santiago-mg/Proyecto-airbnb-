        li: a.transition.hover_text-white(class="hover:text-white" href="/panel/propiedades") Gestiona propiedades
    div
      h4.text-sm.font-bold.uppercase.tracking-wide.text-white Soporte
      ul.mt-4.space-y-2.text-sm.text-brand-200
