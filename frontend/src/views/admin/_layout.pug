doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= (pagina ? pagina + ' · ' : '') + 'Admin EstadiaPro'
    link(rel="stylesheet" href="/css/app.css")
    link(rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E🏕️%3C/text%3E%3C/svg%3E")
    script(src="https://unpkg.com/lucide@latest")
    block head
  include ../partials/alert
  body.bg-slate-50
    .flex.min-h-dvh
      //- Sidebar
      aside.fixed.inset-y-0.left-0.z-30.hidden.w-64.flex-col.bg-brand-950.text-brand-100(class="lg:flex")
        a.flex.items-center.gap-2.px-6.py-6.font-display.text-xl.font-bold.text-white(href="/admin")
          span.flex.h-9.w-9.items-center.justify-center.rounded-xl.bg-coral-500
            i(data-lucide="shield-check" style="width:20px;height:20px")
          | EstadiaPro
        nav.flex-1.space-y-1.px-3
          -
            var items = [
              { href: '/admin', sec: 'dashboard', icon: 'layout-dashboard', label: 'Dashboard' },
              { href: '/admin/propiedades', sec: 'propiedades', icon: 'building-2', label: 'Propiedades' },
              { href: '/admin/usuarios', sec: 'usuarios', icon: 'users', label: 'Usuarios' },
              { href: '/admin/resenas', sec: 'resenas', icon: 'message-square', label: 'Reseñas' },
              { href: '/admin/precios', sec: 'precios', icon: 'trending-up', label: 'Precios dinámicos' },
              { href: '/admin/anuncios', sec: 'anuncios', icon: 'megaphone', label: 'Anuncios' },
              { href: '/admin/auditoria', sec: 'auditoria', icon: 'scroll-text', label: 'Auditoría' }
            ];
          each it in items
            a.flex.items-center.gap-3.rounded-2xl.px-4.py-2.text-sm.font-semibold.transition(href=it.href class=(seccion === it.sec ? 'bg-brand-800 text-white' : 'text-brand-200 hover:bg-brand-900 hover:text-white'))
              i(data-lucide=it.icon style="width:18px;height:18px")
              = it.label
        .border-t.border-brand-900.p-3
          a.flex.items-center.gap-3.rounded-2xl.px-4.py-2.text-sm.font-semibold.text-brand-200.transition(class="hover:bg-brand-900 hover:text-white" href="/")
            i(data-lucide="arrow-left" style="width:18px;height:18px")
            | Volver al sitio
          a.flex.items-center.gap-3.rounded-2xl.px-4.py-2.text-sm.font-semibold.text-rose-300.transition(class="hover:bg-rose-900/40" href="/logout")
            i(data-lucide="log-out" style="width:18px;height:18px")
            | Cerrar sesión

      //- Contenido
      .flex-1(class="lg:pl-64")
        header.sticky.top-0.z-20.flex.items-center.justify-between.border-b.border-slate-200.bg-white.px-6.py-4
          div
            p.text-xs.font-bold.uppercase.tracking-wide.text-brand-600 Panel de administración
            h1.font-display.text-xl.font-bold.text-ink= pagina
          .flex.items-center.gap-3
            a.relative.flex.h-10.w-10.items-center.justify-center.rounded-full.bg-brand-50.text-brand-700(href="/admin/auditoria")
              i(data-lucide="bell" style="width:18px;height:18px")
            .flex.items-center.gap-2.rounded-full.bg-slate-100.py-1.pl-1.pr-3
              span.flex.h-8.w-8.items-center.justify-center.rounded-full.bg-brand-700.text-xs.font-bold.text-white= (usuario.nombre || 'A')[0]
              span.text-sm.font-semibold.text-ink-soft.hidden(class="sm:block")= usuario.nombre
        main.p-6
          if alert
            .mb-6
              +alert(alert)
          block panel
    script(src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js")
    script(src="/js/admin.js")
    block scripts
