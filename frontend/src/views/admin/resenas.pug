extends _layout
include ../partials/mixins

block panel
  if resenas.length
    .grid.gap-4(class="lg:grid-cols-2")
      each r in resenas
        .card.p-5(class=(r.oculta ? 'opacity-60' : ''))
          .flex.items-start.justify-between.gap-3
            div
              .flex.items-center.gap-2
                +stars(r.calificacion, 14)
                if r.oculta
                  span.badge.badge-muted Oculta
              p.mt-2.text-sm.leading-relaxed.text-ink-soft “#{r.comentario}”
              p.mt-3.text-xs.text-ink-muted
                | Por #{r.autor ? r.autor.nombre : '—'} en
                a.ml-1.font-semibold.text-brand-700(href=`/propiedades/${r.propiedadId}` target="_blank")= r.propiedad ? r.propiedad.titulo : 'propiedad'
          .mt-4.flex.gap-2
            if r.oculta
              button.btn-soft.py-2.text-xs(data-admin-action data-api=`/admin/resenas/${r.id}` data-method="PATCH" data-payload=JSON.stringify({ accion: 'mostrar' })) Mostrar
            else
              button.btn-ghost.py-2.text-xs(data-admin-action data-api=`/admin/resenas/${r.id}` data-method="PATCH" data-payload=JSON.stringify({ accion: 'ocultar' })) Ocultar
            button.btn-ghost.py-2.text-xs.text-rose-600(class="hover:border-rose-300" data-admin-action data-confirm="¿Eliminar esta reseña?" data-api=`/admin/resenas/${r.id}` data-method="PATCH" data-payload=JSON.stringify({ accion: 'eliminar' }))
              i(data-lucide="trash-2" style="width:14px;height:14px")
              | Eliminar
  else
    .card.flex.flex-col.items-center.gap-3.p-12.text-center
      i(data-lucide="message-square-off" class="text-brand-400" style="width:44px;height:44px")
      p.text-ink-muted No hay reseñas registradas.
